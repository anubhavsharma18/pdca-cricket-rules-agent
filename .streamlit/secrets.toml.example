# Copy this to secrets.toml for local testing, OR paste these into
# Streamlit Community Cloud → App settings → Secrets.
#
# NEVER commit secrets.toml — it contains live API keys.

AZURE_AI_API_KEY = "your-azure-ai-api-key-here"
AZURE_SEARCH_ENDPOINT = "https://pdca-cricket-search.search.windows.net"
AZURE_SEARCH_ADMIN_KEY = "your-search-admin-key-here"
AZURE_SEARCH_INDEX = "pdca-cricket-rules"
